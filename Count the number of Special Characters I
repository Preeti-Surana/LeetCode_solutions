class Solution(object):
    def numberOfSpecialChars(self, word):
        lower = set()
        upper = set()
        for ch in word:
            if ch.islower():
                lower.add(ch)
            else:
                upper.add(ch.lower())

        count = 0
        for ch in lower:
            if ch in upper:
                count += 1

        return count
        
