class Solution(object):
    def countValidSubarrays(self, nums, x):
        n = len(nums)
        cnt = 0

        for i in range(n):
            total = 0

            for j in range(i, n):
                total += nums[j]
                if total % 10 != x:
                    continue

                first = total
                while first >= 10:
                    first //= 10

                if first == x:
                    cnt += 1
        return cnt
